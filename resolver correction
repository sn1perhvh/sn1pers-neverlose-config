init = function(thisptr, edx)
    if not enabled:get() then return end

    local lp = entity.get_local_player()
    if not lp or lp:get_index() <= 0 or lp:is_alive() == false then return end
    entity.get_players(true, false, function(ent)
        local condition_to_resolve = ent:is_enemy() and ent:is_alive() and not ent:is_dormant()

        if Low_FPS_Mode:get() then
            
            local threat_entity = entity.get_threat()
            if not entity.get_threat() then
                return
            end
        
            
            condition_to_resolve = condition_to_resolve and (threat_entity:get_index() == ent:get_index())
        end
        
        if not condition_to_resolve then
            return
        end
        local name = ent:get_name()
        if name then
            if not player_names[name] then
                player_names[name] = true
            end
        end
        
        local idx = ent:get_index()
        if idx == nil then return end
        if lp:get_index() == idx or ent:is_alive() == false then return end
        
        
        local shot_count = shots_fired[name] or 0
        
        if switch:get() == "Default" then
            resolver_old:main(idx)
        elseif switch:get() == "Imitation" then
            resolver:main(idx)
        elseif switch:get() == "Dynamic" then
            
            if shot_count % 2 == 0 then
                resolver_old:main(idx) 
            else
                resolver:main(idx) 
            end
        end
    end)
    
    
    
    for name, _ in pairs(player_names) do
        local still_exists = false

        entity.get_players(true, false, function(ent)
            if ent:get_name() == name then
                still_exists = true
            end
        end)

        if not still_exists then
            player_names[name] = nil 
        end
    end
end
