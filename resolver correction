local function handleAutoTeleport(cmd)
    local localPlayer = entity.get_local_player()
    
    if not autoTeleportSwitch:get() or not localPlayer or not localPlayer:is_alive() then
        return
    end
   
    local currentWeapon = localPlayer:get_player_weapon()
    local weaponClass = currentWeapon:get_classname()
    if string.match(weaponClass, "Grenade") then
        return
    end
   
    local function canHitPlayer(targetEntity)
        local damage, trace = utils.trace_bullet(
            targetEntity, 
            targetEntity:get_hitbox_position(3), 
            localPlayer:get_hitbox_position(3)
        )
 
        return damage > 0 and (trace.entity == localPlayer)
    end
    
    local needTeleport = false
    for _, enemyPlayer in pairs(entity.get_players(true)) do
        if enemyPlayer ~= localPlayer and canHitPlayer(enemyPlayer) then
            needTeleport = true
            break
        end
    end
    
    if needTeleport then
        cmd.force_defensive = true
        
        local rageFakeLagControl = ui.find("Aimbot", "Ragebot", "Main", "Double Tap", "Fake Lag Limit")
        rageFakeLagControl:override(math.random(10))
        
        if rage.exploit:get() == 1 then
            rage.exploit:force_teleport()
        end
        
        rageFakeLagControl:override(math.random(5))
        
        if globals.tickcount % teleportDelaySlider:get() == teleportDelaySlider:get() - 1 then
            rage.exploit:force_charge()
        end
    else
        ui.find("Aimbot", "Ragebot", "Main", "Double Tap", "Fake Lag Limit"):override(nil)
    end
end
