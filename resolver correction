function generate_unique_hash()
    
    local random_value = math.random(0, 0xFFFFFFFF) + math.random(0, 0xFFFFFFFF)
    local timestamp = math.floor(math.random() * 1000000000)  

    
    local hash = 0
    local combined_value = tostring(random_value + timestamp)

    
    for i = 1, #combined_value do
        hash = (hash * 31 + string.byte(combined_value, i)) % 0xFFFFFFFF
    end
    
    
    local hash_string = string.format("%x", hash)  
    while #hash_string < 16 do  
        hash_string = hash_string .. math.random(0, 15)  
    end
    
    return hash_string:sub(1, 16)  
end

